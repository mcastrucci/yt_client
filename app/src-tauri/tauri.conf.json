{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Descargador YouTube",
  "version": "0.1.0",
  "identifier": "com.maximilianocastrucci.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Descargador YouTube",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../dependencies/mac/": "dependencies/mac/",
      "../../dependencies/windows/": "dependencies/windows/"
    }
  }
}
